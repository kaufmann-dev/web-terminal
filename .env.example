# Application
NODE_ENV=production
PORT=3000

# Authentication
OIDC_ISSUER_URL=https://identity.example/application/o/web-terminal/
OIDC_CLIENT_ID=replace-with-provider-client-id
OIDC_CLIENT_SECRET=replace-with-provider-client-secret
OIDC_ALLOWED_SUBJECT=replace-with-allowed-user-subject
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
PUBLIC_ORIGIN=http://localhost:3000

# Terminal paths
TERMINAL_WORKDIR=/code
TERMINAL_HOME=/code
