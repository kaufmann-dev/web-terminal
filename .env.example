# Application
NODE_ENV=production
PORT=3000
TRUST_PROXY=true

# Authentication
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# TTYD backend (must be localhost/internal; never exposed publicly)
TTYD_URL=http://127.0.0.1:7681
